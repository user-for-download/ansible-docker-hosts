# group_vars/docker.yml.example
# Copy to docker.yml and fill in your values
---
docker_edition: "ce"
docker_channel: "stable"
docker_version: "latest"
docker_users:
  - "{{ target_user }}"

docker_compose_version: "2.32.4"
docker_compose_install_method: "plugin"

docker_daemon_config:
  log-driver: "json-file"
  log-opts:
    max-size: "10m"
    max-file: "3"
  storage-driver: "overlay2"
  live-restore: true
  userland-proxy: false

docker_insecure_registries: []
docker_registry_mirrors: []

configure_docker_storage: true
