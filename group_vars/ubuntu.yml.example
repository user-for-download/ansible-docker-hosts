# group_vars/ubuntu.yml.example
# Copy to ubuntu.yml and fill in your values
---
# Host Settings
disable_ipv6: true

core_dependencies:
  - aptitude
  - apt-transport-https
  - ca-certificates
  - curl
  - git
  - software-properties-common
  - apache2-utils
  - tree
  - wget
  - tcpdump
  - lsb-release
  - ufw
  - fail2ban

host_settings_cloud_init_directories:
  - /etc/cloud/
  - /var/lib/cloud/

host_settings_ipv6_disable_params:
  - net.ipv6.conf.all.disable_ipv6
  - net.ipv6.conf.default.disable_ipv6
  - net.ipv6.conf.lo.disable_ipv6

host_settings_update_timers:
  - apt-daily.timer
  - apt-daily-upgrade.timer

# NTP
ntp_servers:
  - "10.0.2.10"
  # - "10.0.1.10"
ntp_fallback_pools: []

# Security
ssh_port: 22
ssh_allowed_network: "{{ trusted_networks }}"
fail2ban_ignore_ips: "{{ ['127.0.0.1/8'] + trusted_networks }}"
fail2ban_bantime: 3600
fail2ban_findtime: 600
fail2ban_maxretry: 5
fail2ban_ssh_maxretry: 3

# vault_password: set via --ask-vault-pass or VAULT_PASSWORD env var
