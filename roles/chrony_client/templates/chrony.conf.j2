# {{ ansible_managed }}

{% for server in ntp_servers %}
server {{ server }} iburst
{% endfor %}

{% for pool in ntp_fallback_pools | default([]) %}
pool {{ pool }} iburst
{% endfor %}

driftfile /var/lib/chrony/chrony.drift
makestep 1.0 3
rtcsync
logdir /var/log/chrony
log measurements statistics tracking